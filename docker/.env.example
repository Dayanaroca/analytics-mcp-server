# Zoho Analytics MCP - two account setup
#
# Copy these variables into Railway > Variables, or copy this file to .env for
# local Docker testing. Do not commit real secrets.

# Optional default account used when the tool call does not pass account.
# Accepted values: 1, 2, account_1, account_2, or the aliases below.
ANALYTICS_DEFAULT_ACCOUNT=1

# Account 1 - Gran Azul
ANALYTICS_ACCOUNT_1_ALIAS=gran_azul
ANALYTICS_CLIENT_ID_1=
ANALYTICS_CLIENT_SECRET_1=
ANALYTICS_REFRESH_TOKEN_1=
ANALYTICS_ORG_ID_1=20103657962
ACCOUNTS_SERVER_URL_1=https://accounts.zoho.eu
ANALYTICS_SERVER_URL_1=https://analyticsapi.zoho.eu

# Account 2
ANALYTICS_ACCOUNT_2_ALIAS=cuenta_2
ANALYTICS_CLIENT_ID_2=
ANALYTICS_CLIENT_SECRET_2=
ANALYTICS_REFRESH_TOKEN_2=
ANALYTICS_ORG_ID_2=
ACCOUNTS_SERVER_URL_2=https://accounts.zoho.eu
ANALYTICS_SERVER_URL_2=https://analyticsapi.zoho.eu

# Local/download directory used by file tools.
ANALYTICS_MCP_DATA_DIR=/tmp/zoho-analytics-mcp

# Optional limits
QUERY_DATA_RESULT_ROW_LIMITS=20
QUERY_DATA_POLLING_INTERVAL=4
QUERY_DATA_QUEUE_TIMEOUT=120
QUERY_DATA_QUERY_EXECUTION_TIMEOUT=30
ANALYTICS_WORKSPACE_LIST_RESULT_SIZE=20
ANALYTICS_VIEW_LIST_RESULT_SIZE=15
